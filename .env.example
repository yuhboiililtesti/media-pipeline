# Media Pipeline Configuration
# Copy this to .env and fill in your values

# API Keys (required)
TMDB_KEY=your_tmdb_api_key_here
RADARR_API_KEY=your_radarr_api_key
SONARR_API_KEY=your_sonarr_api_key
PROWLARR_API_KEY=your_prowlarr_api_key
PLEX_TOKEN=your_plex_token

# qBittorrent
QBIT_USERNAME=admin
QBIT_PASSWORD=your_password

# Paths
MEDIA_20TB=/mnt/media
MEDIA_8TB=/mnt/media2
DOWNLOADS=/mnt/media/downloads
PLEX_METADATA=/var/lib/plex
TDARR_CACHE=/mnt/media/Encode-Tmp

# Network
SERVER_IP=10.0.0.201
LAPTOP_IP=10.0.0.234
DESKTOP_IP=10.0.0.192
QBIT_OVERFLOW_PORT=8083
QBIT_LAPTOP_PORT=8080
RADARR_PORT=7878
SONARR_PORT=8989
PROWLARR_PORT=9696
PLEX_PORT=32400

# Modes (download limits)
MAX_DL=50
HARD_DL=20
MED_DL=3
SOFT_DL=0

# Schedule
MAX_MODE_TIME=04:00
MED_MODE_TIME=12:00
DISCOVERY_TIME=02:00
BACKUP_TIME=03:00

# Thresholds
AUTO_ADD_CONFIDENCE=60
DISK_WARN_PCT=90
DISK_SLOW_PCT=95
DISK_STOP_PCT=98
